# ---------------------------------------------------------------------------
# LMS Backend - Environment Variables
# Copy this file to .env and fill in real values. Never commit .env itself.
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000

# Frontend origin allowed by CORS (must match exactly, no trailing slash)
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/lms_db

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=lms_token

# bcrypt
BCRYPT_SALT_ROUNDS=10

# Cloudinary (https://cloudinary.com/console) - used to store salary slips
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Logging
LOG_LEVEL=info
